{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ListBucketStatement",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": ["arn:aws:s3:::your-artifacts-bucket"],
      "Condition": {
        "StringEquals": { "aws:ResourceAccount": ["${AWS_ACCOUNT_ID}"] }
      }
    },
    {
      "Sid": "S3GetObjectStatement",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": [
        "arn:aws:s3:::your-artifacts-bucket/projects/piter-aiops/knowledge_base/*",
        "arn:aws:s3:::your-artifacts-bucket/projects/piter-aiops/agent/*"
      ],
      "Condition": {
        "StringEquals": { "aws:ResourceAccount": ["${AWS_ACCOUNT_ID}"] }
      }
    }
  ]
}
