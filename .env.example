# PITER AiOps environment template
# Copy to .env for local use. Do not commit real secrets or private IDs.

# --- AWS credentials (pick one approach) ---
AWS_REGION=us-east-1
# Leave AWS_PROFILE empty or omit to use default credential chain / bearer token.
# AWS_PROFILE=default

# --- Bedrock (required when PITER_USE_BEDROCK=true and RAG_BACKEND=agent) ---
PITER_USE_BEDROCK=true
PITER_RAG_BACKEND=agent
PITER_AWS_REGION=us-east-1
PITER_BEDROCK_AGENT_ID=your_agent_id_here
PITER_BEDROCK_AGENT_ALIAS_ID=your_agent_alias_id_here
PITER_BEDROCK_KB_ID=your_kb_id_here
PITER_BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/amazon.nova-lite-v1:0
PITER_BEDROCK_DATA_SOURCE_ID=your_data_source_id_here
PITER_BEDROCK_NUM_RESULTS=5

# Legacy aliases (optional if PITER_* vars above are set)
BEDROCK_AGENT_ID=your_agent_id_here
BEDROCK_AGENT_ALIAS_ID=your_agent_alias_id_here
BEDROCK_KB_ID=your_kb_id_here
BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/amazon.nova-lite-v1:0
BEDROCK_DATA_SOURCE_ID=your_data_source_id_here

# --- S3 knowledge base sync ---
PITER_S3_BUCKET=your_bucket_name_here
PITER_S3_PREFIX=projects/piter-aiops/knowledge_base
S3_BUCKET=your_bucket_name_here
S3_PREFIX=projects/piter-aiops/knowledge_base

# --- Flask ---
PITER_FLASK_SECRET_KEY=change-me
FLASK_SECRET_KEY=change-me
FLASK_ENV=development
MAX_UPLOAD_BYTES=5242880

# --- Hybrid fallback (polished local KB when Bedrock fails) ---
PITER_LOCAL_FALLBACK=true

# --- Docker Compose (local-first unless opted in) ---
PITER_DOCKER_USE_BEDROCK=false

# --- Notification safety defaults: preview/mock only ---
# Default is preview/mock: "Escalate to on-call" renders the SMS + email that
# WOULD be sent and sends nothing. Live dispatch requires BOTH the env flag and
# a valid confirmation token, and is capped to one send per incident.
PITER_NOTIFICATION_MODE=preview
PITER_ENABLE_LIVE_DISPATCH=false
PITER_NOTIFICATION_REQUIRE_CONFIRMATION=true
PITER_NOTIFICATION_CONFIRMATION_TOKEN=
PITER_NOTIFICATION_ALLOWLIST=
PITER_NOTIFICATION_ALLOWED_SEVERITIES=P1,P2

# Escalation recipients come ONLY from these env vars (NEVER committed to git).
# Set them on the instance/--env-file when going live. us-east-1 SES + SNS.
PITER_ESCALATION_EMAIL=
PITER_ESCALATION_SMS=
PITER_SES_SENDER_EMAIL=
