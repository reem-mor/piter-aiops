{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowPublishToPiterEscalationTopicOnly",
      "Effect": "Allow",
      "Action": ["sns:Publish"],
      "Resource": "arn:aws:sns:us-east-1:${AWS_ACCOUNT_ID}:piter-aiops-escalation"
    },
    {
      "Sid": "AllowSesSendFromVerifiedIdentitiesOnly",
      "Effect": "Allow",
      "Action": ["ses:SendEmail", "ses:SendRawEmail"],
      "Resource": [
        "arn:aws:ses:us-east-1:${AWS_ACCOUNT_ID}:identity/your-sender@example.com",
        "arn:aws:ses:us-east-1:${AWS_ACCOUNT_ID}:identity/your-email@example.com",
        "arn:aws:ses:us-east-1:${AWS_ACCOUNT_ID}:configuration-set/piter-aiops-escalations"
      ],
      "Condition": {
        "StringEquals": {
          "ses:FromAddress": ["your-sender@example.com", "your-email@example.com"]
        }
      }
    },
    {
      "Sid": "AllowSesReadOnlyStatus",
      "Effect": "Allow",
      "Action": [
        "ses:GetAccount",
        "ses:GetSendQuota",
        "ses:GetEmailIdentity",
        "ses:ListEmailIdentities"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowSmsVoiceDispatch",
      "Effect": "Allow",
      "Action": [
        "sms-voice:SendTextMessage",
        "sms-voice:DescribeAccountAttributes",
        "sms-voice:DescribePhoneNumbers"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowSnsSmsReadiness",
      "Effect": "Allow",
      "Action": ["sns:GetSMSAttributes", "sns:ListSMSSandboxPhoneNumbers"],
      "Resource": "*"
    }
  ]
}
