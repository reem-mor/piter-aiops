{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadPiterNotificationParameters",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath"
      ],
      "Resource": [
        "arn:aws:ssm:us-east-1:329597159579:parameter/piter-aiops/notification",
        "arn:aws:ssm:us-east-1:329597159579:parameter/piter-aiops/notification/*"
      ]
    },
    {
      "Sid": "DecryptSsmSecureStrings",
      "Effect": "Allow",
      "Action": ["kms:Decrypt"],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "kms:ViaService": "ssm.us-east-1.amazonaws.com"
        }
      }
    }
  ]
}
